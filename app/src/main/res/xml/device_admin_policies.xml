<?xml version="1.0" encoding="utf-8"?>
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <!-- Force lock policy - allows the app to lock the device -->
        <force-lock />
        <!-- Reset password policy -->
        <reset-password />
        <!-- Disable camera -->
        <disable-camera />
        <!-- Disable keyguard features -->
        <disable-keyguard-features />
        <!-- Monitor device administrators -->
        <limit-password-length />
    </uses-policies>
</device-admin>