<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <ImageView
        android:id="@+id/shieldIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Shield Icon"
        android:src="@drawable/ic_launcher_foreground" />

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:textColor="@color/primary_color" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/admin_disabled"
        android:textSize="18sp"
        android:layout_marginBottom="32dp"
        android:textColor="@color/error_color" />

    <Button
        android:id="@+id/enableAdminButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/enable_admin"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/primary_color" />

    <Button
        android:id="@+id/lockButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/lock_device"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/error_color"
        android:enabled="false" />

    <Button
        android:id="@+id/startServiceButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/service_running"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/secondary_color"
        android:enabled="false" />

</LinearLayout>